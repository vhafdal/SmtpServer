<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- The library's own dependencies (MinVer, Microsoft.*, System.*) and the test dependencies all come
       from nuget.org. The devop-marketplace source carries no package this repo restores; it exists so the
       release pipeline can push the built DevOp.SMTPServer package to nuget.devop.is (the CI job injects the
       basic-auth credential into this source at build time). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="devop-marketplace" value="https://nuget.devop.is/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="devop-marketplace">
      <package pattern="DevOp.*" />
    </packageSource>
  </packageSourceMapping>
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
